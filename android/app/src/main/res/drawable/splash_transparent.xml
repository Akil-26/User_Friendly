<?xml version="1.0" encoding="utf-8"?>
<!-- Splash icon that is the SAME color as the background (#FDF6EC).
     Android 12+ requires a non-empty drawable here — using a transparent/empty
     vector causes it to fall back to the app launcher icon.
     By filling with the exact background color the icon is invisible. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#FDF6EC"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />
</vector>
